{
  "name": "transcriptor",
  "version": "0.3.1",
  "description": "Export Discord channels to HTML, Markdown, or TXT transcripts — optimized for large volumes.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "static"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "keywords": [
    "discord",
    "transcript",
    "html",
    "markdown",
    "export",
    "discord.js"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yazouv/TranScriptor.git"
  },
  "homepage": "https://github.com/yazouv/TranScriptor",
  "bugs": {
    "url": "https://github.com/yazouv/TranScriptor/issues"
  },
  "peerDependencies": {
    "discord.js": "^14.0.0 || ^15.0.0"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    },
    "archiver": {
      "optional": true
    }
  },
  "dependencies": {
    "discord-markdown-parser": "~1.2.0",
    "undici": "^7.0.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "archiver": "^7.0.0",
    "discord.js": "^14.16.0",
    "eslint": "^9.0.0",
    "jiti": "^2.6.1",
    "sharp": "^0.33.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.2"
  }
}
